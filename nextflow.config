// ============================================================================
//  NEW USERS: edit the paths in this file to point to your own data/references.
//  Every absolute path below is a placeholder from the original study system
//  and MUST be updated for your environment. See docs/REPRODUCIBILITY.md and
//  data/README.md for what each file is and where to obtain it.
// ============================================================================

// Define parameters as flat key-value pairs
params.traits_config = "${projectDir}/json_files/GWAS_input.json"   // trait/GWAS table (see json_files/GWAS_input.json)
params.outdir = "${projectDir}/results"
params.num_random_sets = 1000   // number of null gene sets per method (study used 1000; use a small value to smoke-test)
params.randomization_methods = ['birewire','keeppathsize']
params.bfile = "/path/to/reference/g1000_eur"                       // MAGMA LD reference (1000G EUR) plink prefix
params.geneset_real = "${projectDir}/data/c2.all.v2023.2.Hs.symbols.gmt_filtered.txt"
params.ukb_dir = "/path/to/ukb/"                                   // PRSet UKB validation cohort directory
params.gtf_reference = "/path/to/reference/Homo_sapiens.GRCh37.75.gtf.gz"

// PRSet tool paths (used by modules/prset/prset.nf)
params.prsice_bin = "/path/to/PRSice_linux"                        // PRSice/PRSet executable
params.prset_background = "/path/to/msigdb.genes.txt:gene"         // PRSet --background gene coordinate file (with :gene suffix)

//workflow control parameters
params.run_magma = true
params.run_prset = true
params.run_pascalx = true
params.run_empirical = true
params.run_opentargets = true
params.run_ot_correlation = true
params.run_tissue_correlation = true
params.run_malacards_correlation = true
params.run_gsamixer = true
params.run_fpr_analysis = true
params.run_dorothea_correlation = true

// GSA-MiXeR container command (uses singularity, consistent with gsamixer.sh)
params.mixer_sif = "/path/to/gsa_mixer/gsa-mixer.sif"
params.mixer_py  = "singularity exec --home pwd:/home ${params.mixer_sif} python /tools/mixer/precimed/mixer.py"

// PascalX container and reference data
params.pascalx_sif = "/path/to/pascalx_singularity.sif"
// Container-internal paths point to mounted host directories (see singularity{} block below)
params.pascalx_ref_panel = "/data/pascalx_reference/EUR.1KG.GRCh37"
params.pascalx_genome_annot = "/data/msigdbgenes.regions"

// References (@ is the GSA-MiXeR per-chromosome wildcard)
params.mixer_ref_bim     = "/path/to/gsa_mixer/1000G_EUR_Phase3_plink/1000G.EUR.QC.@.bim"
params.mixer_ref_loadlib = "/path/to/gsa_mixer/1000G_EUR_Phase3_plink/1000G.EUR.QC.@.bin"
params.mixer_ref_annot   = "/path/to/gsa_mixer/1000G_EUR_Phase3_plink/baseline_v2.2_1000G.EUR.QC.@.annot.gz"

// Gene set annotation CSVs (GSA-MiXeR reference, distributed with the tool)
params.mixer_go_base      = "/path/to/gsa_mixer/reference/gsa-mixer-baseline-annot_10mar2023.csv"
params.mixer_go_full      = "/path/to/gsa_mixer/reference/gsa-mixer-gene-annot_10mar2023.csv"
params.mixer_go_full_test = "/path/to/gsa_mixer/reference/gsa-mixer-hybridLOO-annot_10mar2023.csv"

// Any extra mixer flags, or empty
params.mixer_extra_flags = "--seed 1000 --hardprune-r2 0.6 --threads 8"

// Resources
process {
  withName: prepare_gsamixer_sumstats {
    executor = 'lsf'; queue = 'premium'; cpus = 1; memory = '15G'; time = '20m'
    clusterOptions = '-P acc_paul_oreilly'
  }
  withName: split_gsamixer_sumstats {
    executor = 'lsf'; queue = 'premium'; cpus = 1; memory = '4G'; time = '20m'
    clusterOptions = '-P acc_paul_oreilly'
  }
  withName: gsamixer_plsa_base {
    executor = 'lsf'; queue = 'premium'; cpus = 8; memory = '30G'; time = '10h'
    clusterOptions = '-P acc_paul_oreilly'
  }
  withName: gsamixer_plsa_full {
    executor = 'lsf'; queue = 'premium'; cpus = 8; memory = '40G'; time = '24h'
    clusterOptions = '-P acc_paul_oreilly'
  }
  withName: convert_random_gmt_for_gsamixer {
    executor = 'lsf'; queue = 'premium'; cpus = 1; memory = '4G'; time = '1h'
    clusterOptions = '-P acc_paul_oreilly'
  }
  withName: gsamixer_plsa_full_random {
    executor = 'lsf'; queue = 'premium'; cpus = 8; memory = '40G'; time = '24h'
    clusterOptions = '-P acc_paul_oreilly'
  }
  withName: convert_gmt_for_gsamixer {
    executor = 'lsf'
    queue = 'premium'
    cpus = 1
    memory = '4G'
    time = '20m'
    clusterOptions = '-P acc_paul_oreilly'
  }
  
  withName: generate_birewire_random_gmts {
    executor = 'lsf'
    queue = 'premium'
    cpus = 1
    memory = '15G'
    time = '12h'
    clusterOptions = '-P acc_paul_oreilly'
  }
}

// Directory containing OpenTargets associationByDatatypeDirect JSON files
params.opentargets_json_dir = "/path/to/opentargets/associationByDatatypeDirect"

params {
  background = 'msigdbgenes'

  gene_files = [
    msigdbgenes: "/path/to/data/msigdbgenes.regions",
    realgenes  : "/path/to/data/proteincoding.regions"
  ]
  
  // GMT directories for different randomization methods
  gmt_dirs = [
    birewire: "${params.outdir}/randomized_gene_sets/random_birewire",
    keeppathsize: "${params.outdir}/randomized_gene_sets/random_keeppathsize"
  ]
  
  // Control whether to generate random GMT files at pipeline start
  generate_random_gmts = true

  // Directory for scripts
  scripts_dir = "${projectDir}/scripts"

  opentargets_supported_traits = [
    "t2d", "cad", "ad", "mdd", "scz", "ibd", "breast"
  ]

  // tissue specificity data (GTEx-derived specificity tables; see data/README.md)
    tissue_expression_data = "/path/to/tissue_specificity/specificity"

  opentargets_sig_threshold = 0.00625

  malacards_path = "/path/to/Malacards"

  // Only run MalaCards for these traits (case-insensitive)
  malacards_traits = 'bmi,cad,t2d,mdd,ad,scz,ibd,breast'

  //dorothea analysis (precomputed pairwise pathway scores; see data/README.md)
  dorothea_scores_path = "/path/to/dorothea_pairwise_scores.csv"
}

// for job submission
process{
  withName: run_random_sets {
    executor = 'lsf'
    queue='premium'
    clusterOptions='-P acc_paul_oreilly'
    cpus = '1'
    memory = '4G'
    time = '1h'
  }
  withName: run_gene_analysis {
    executor = 'lsf'
    queue='premium'
    clusterOptions = '-P acc_paul_oreilly'
    cpus = '1'
    memory = '50000 MB'
    time = '12h'
  }
  withName: gwas_remove_dup_snps {
    executor = 'lsf'
    queue='premium'
    cpus = '1'
    memory = '16G'
    time = '20m'
    clusterOptions = '-P acc_paul_oreilly'
  }
  withName: run_random_sets_prset {
    executor = 'lsf'
    queue = 'premium'
    time = '4h'
    memory = '80G'
    clusterOptions = '-P acc_paul_oreilly -R "span[ptile=1]"'
  }
  withName: calc_empirical_pvalues {
    executor = 'lsf'
    queue = 'premium'
    clusterOptions = '-P acc_paul_oreilly'
    cpus = '1'
    memory = '50G'
    time = '2h'
  }
  withName: 'opentargets_stats_correlation' {
    executor = 'lsf'
    queue = 'premium'
    clusterOptions = '-P acc_paul_oreilly'
    cpus = '1'
    memory = '12G'
    time = '0.5h'
  }
  withName: 'tissue_correlation_analysis' {
    executor = 'lsf'
    queue = 'premium'
    clusterOptions = '-P acc_paul_oreilly'
    cpus = '2'
    memory = '10G'
    time = '1h'
  }
  withName: 'malacards_correlation' {
    executor = 'lsf'
    queue = 'premium'
    clusterOptions = '-P acc_paul_oreilly'
    cpus = '1'
    memory = '8G'
    time = '30m'
  }
  withName: run_real_prset {
    executor = 'lsf'
    queue = 'premium'
    time = '4h'
    cpus = 1  
    memory = '80G'
    clusterOptions = '-P acc_paul_oreilly -R "span[ptile=1]"'
  }
  withName: calculate_fpr {
    executor = 'lsf'
    queue = 'premium'
    clusterOptions = '-P acc_paul_oreilly'
    cpus = '1'
    memory = '8G'
    time = '1h'
  }
    withName: 'dorothea_correlation' {
    executor = 'lsf'
    queue = 'premium'
    clusterOptions = '-P acc_paul_oreilly'
    cpus = '1'
    memory = '8G'
    time = '30m'
  }
  withName: run_pascalx_genes {
    executor = 'lsf'
    queue = 'premium'
    clusterOptions = '-P acc_paul_oreilly'
    cpus = '1'
    memory = '50G'
    time = '4h'
    beforeScript = 'module load apptainer/1.3.6'  // Add this line
  }
  withName: run_real_pascalx {
    executor = 'lsf'
    queue = 'premium'
    clusterOptions = '-P acc_paul_oreilly'
    cpus = '1'
    memory = '50G'
    time = '4h'
    beforeScript = 'module load apptainer/1.3.6'  // Add this line
  }
  withName: run_random_sets_pascalx {
    executor = 'lsf'
    queue = 'premium'
    clusterOptions = '-P acc_paul_oreilly'
    cpus = '1'
    memory = '50G'
    time = '4h'
    beforeScript = 'module load apptainer/1.3.6'  // Add this line
  }
}

executor {
  queueSize = 500
}

singularity {
  enabled = true
  autoMounts = true
  runOptions = "--bind ${projectDir}/scripts:/scripts:ro," +
               "${projectDir}/data:/data:ro," +
               "${params.outdir}/randomized_gene_sets:/randomized_gene_sets:ro," +
               "${projectDir}/data/pascalx_reference:/pascalx_ref"   // writable — no :ro
}

// Update PascalX reference paths to use writable location
params.pascalx_ref_panel    = "/pascalx_ref/EUR.1KG.GRCh37"   // matches the new mount
params.pascalx_genome_annot = "/data/msigdbgenes.regions"
